{
  "expo": {
    "name": "SpeakReadyMY",
    "slug": "speakready-my",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "speakready",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.hoik.speakreadymy"
    },
    "android": {
      "versionCode": 4,
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ],
      "package": "com.hoik.speakreadymy",
      "runtimeVersion": {
        "policy": "appVersion"
      }
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-status-bar",
      [
        "expo-audio",
        {
          "microphonePermission": "SpeakReadyMY needs microphone access to assess your English pronunciation.",
          "enableBackgroundPlayback": false,
          "enableBackgroundRecording": false
        }
      ],
      "expo-font",
      [
        "@sentry/react-native",
        {
          "organization": "korea-telecom",
          "project": "python-0k"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "57cccf56-7494-4844-a508-89b6cb754c3a"
      }
    },
    "updates": {
      "url": "https://u.expo.dev/57cccf56-7494-4844-a508-89b6cb754c3a"
    }
  }
}
