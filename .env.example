# SpeakReadyMY — 환경변수 템플릿
# 이 파일을 복사해서 .env.local 로 저장 후 실제 값 입력

# ─── 앱 기본 ───────────────────────────────────────
EXPO_PUBLIC_API_URL=http://localhost:8000
# "false" 로 설정하면 실제 API 호출, 기본값(미설정/true)은 Mock 모드
EXPO_PUBLIC_USE_MOCK=true
EXPO_PUBLIC_SENTRY_DSN=

# ─── OpenAI ────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_GPT_MODEL=gpt-4o
OPENAI_FEEDBACK_MODEL=gpt-4.1-nano

# ─── Azure Speech ──────────────────────────────────
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=eastus
FFMPEG_BINARY=ffmpeg

# ─── Supabase ──────────────────────────────────────
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=

# ─── Auth (옵션) ────────────────────────────────────
JWT_SECRET=
JWT_REFRESH_EXPIRE_MINUTES=43200
CORS_ALLOW_ORIGINS=exp://localhost:8081,speakready://
APP_SECRET_ID=
AI_RATE_LIMIT_WINDOW_SECONDS=60
AI_RATE_LIMIT_MAX_REQUESTS=30
API_THROTTLE_BURST_LIMIT=20
API_THROTTLE_RATE_LIMIT=10
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.05
SENTRY_TEST_TOKEN=

# ─── Backend database (배포용) ───────────────────────
# 로컬 기본값은 backend/.env.example 참고
DATABASE_URL=
