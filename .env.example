# SpeakReadyMY — 환경변수 템플릿
# 이 파일을 복사해서 .env.local 로 저장 후 실제 값 입력

# ─── 앱 기본 ───────────────────────────────────────
EXPO_PUBLIC_API_URL=http://localhost:8000
# "false" 로 설정하면 실제 API 호출, 기본값(미설정/true)은 Mock 모드
EXPO_PUBLIC_USE_MOCK=true

# ─── OpenAI ────────────────────────────────────────
OPENAI_API_KEY=

# ─── Azure Speech ──────────────────────────────────
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=eastus

# ─── Supabase ──────────────────────────────────────
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── Auth (옵션) ────────────────────────────────────
JWT_SECRET=
