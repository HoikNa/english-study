# Database
DATABASE_URL=sqlite:///./backend/.data/speakready.sqlite3
# Production example:
# DATABASE_URL=postgresql://postgres:<password>@<host>:5432/postgres

# Auth
JWT_SECRET=
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440
JWT_REFRESH_EXPIRE_MINUTES=43200
CORS_ALLOW_ORIGINS=exp://localhost:8081,speakready://
APP_SECRET_ID=

# Azure Speech
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=eastus
FFMPEG_BINARY=ffmpeg

# OpenAI
OPENAI_API_KEY=
OPENAI_TTS_VOICE=nova
OPENAI_GPT_MODEL=gpt-4o
OPENAI_FEEDBACK_MODEL=gpt-4.1-nano

# Supabase
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
SUPABASE_STORAGE_BUCKET=tts-cache

# AWS
AWS_REGION=ap-northeast-2

# Monitoring
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.05
SENTRY_TEST_TOKEN=
ENVIRONMENT=development

# Cost Control
GPT_MONTHLY_BUDGET_USD=30
GEMINI_FALLBACK_ENABLED=true
AI_RATE_LIMIT_WINDOW_SECONDS=60
AI_RATE_LIMIT_MAX_REQUESTS=30
API_THROTTLE_BURST_LIMIT=20
API_THROTTLE_RATE_LIMIT=10
